# =============================================================================
# Dependencies
# =============================================================================
node_modules/
.pnp/
.pnp.js

# =============================================================================
# Next.js build output
# =============================================================================
.next/
out/
.vercel/

# =============================================================================
# Large media files — DO NOT commit to git
# These should be hosted on Cloudinary, S3, or similar
# =============================================================================

# Images
*.jpg
*.jpeg
*.png
*.gif
*.webp
*.avif
*.bmp
*.tiff
*.tif
*.ico
*.heic
*.heif

# Videos
*.mp4
*.webm
*.mov
*.avi
*.mkv
*.wmv
*.m4v

# Audio
*.mp3
*.wav
*.flac
*.aac
*.ogg
*.m4a

# Entire heavy asset directories
public/gallery/
public/images/
public/backgrounds/
public/conductors/
public/composerheads/
public/videos/
public/favicon/

# =============================================================================
# Keep SVGs (they're tiny text files, not raster images)
# =============================================================================
!public/logos/*.svg

# =============================================================================
# Environment and secrets
# =============================================================================
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# =============================================================================
# OS junk
# =============================================================================
.DS_Store
Thumbs.db
desktop.ini
__MACOSX/

# =============================================================================
# Editor / IDE
# =============================================================================
.vscode/
.idea/
*.swp
*.swo
*~

# =============================================================================
# Debug and logs
# =============================================================================
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.npm/

# =============================================================================
# Testing
# =============================================================================
coverage/

# =============================================================================
# Misc
# =============================================================================
*.zip
*.tar.gz
*.rar